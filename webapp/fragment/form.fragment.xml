<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog draggable="true" resizable="true">
        <f:SimpleForm editable="true">

        <Label text="Name"/>
        <Input value="{uiModel>/name}"/>

        <Label text="LastName"/>
        <Input value="{uiModel>/lastName}" />

        <Label text="Amount"/>
        <Input value="{uiModel>/amount}"/>

        <Button
            text="Submit"
            type="Emphasized"
            press="onSubmit"/>

    </f:SimpleForm>

    <beginButton>
        <Button text="ok" press="onSubmit"></Button>
    </beginButton>
    <endButton>
        <Button text="close" press="onClose"></Button>
    </endButton>
    </Dialog>

</core:FragmentDefinition>