<mvc:View
    controllerName="demofiori.project1.controller.Validation"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page title="Input Validation">
        <Input value="{uiModel>/firstName}" change="onNameChange"></Input>
        <Input value="{uiModel>/amount}" change="onAmountChange"></Input>

        <Button text="Submit" press="onSubmit"></Button>
    </Page>
</mvc:View>