<mvc:View
    controllerName="demofiori.project1.controller.Validation"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page title="Input Validation">
        <Input value="{ path: 'uiModel>/firstName',
                        type: 'sap.ui.model.type.String'}"></Input>
        <Input value="{ path: 'uiModel>/lastName',
                        type: 'sap.ui.model.type.String'}"></Input>
        <Input value="{ path: 'uiModel>/amount',
                        type: 'sap.ui.model.type.Integer'}"></Input>
        <DatePicker value="{
                        path: 'uiModel>/DOB',
                        type: 'sap.ui.model.type.Date'}"></DatePicker>

        <Button text="Submit" press="onSubmit"></Button>
    </Page>
</mvc:View>