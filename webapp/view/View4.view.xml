<mvc:View
    controllerName="demofiori.project1.controller.View4"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns:uxap="sap.uxap"
>
    <Page 
        id="page4"
        title="{i18n>view4Title}">

        <uxap:ObjectPageLayout id="objectPageLayout" showHeaderContent="true" useIconTabBar="true">

        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle >
                <uxap:heading>
                    <Title text="Employee Management"></Title>
                </uxap:heading>

                <uxap:actions>
                    <Button text="Go to Page" press="onPressNavigate"></Button>
                </uxap:actions>

            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <uxap:headerContent>
            <Text text="Employee Id: 0741"></Text>
        </uxap:headerContent>

        <uxap:sections>
                <uxap:ObjectPageSection title="Personal Information">
                    <uxap:ObjectPageSubSection>
                        <Text text="Name: John Doe"></Text>
                        <Text text="Age: 30"></Text>
                        <Text text="Position: Software Engineer"></Text>
                    </uxap:ObjectPageSubSection>
                </uxap:ObjectPageSection>
    
                <uxap:ObjectPageSection title="Contact Information">
                    <uxap:ObjectPageSubSection>
                        <Text text="Email: john.doe@company.com"></Text>
                    </uxap:ObjectPageSubSection>
                </uxap:ObjectPageSection>
        </uxap:sections>

        </uxap:ObjectPageLayout>

    </Page>
</mvc:View>